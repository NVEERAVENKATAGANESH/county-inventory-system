{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://county-inventory-system.onrender.com/api/:path*"
    },
    {
      "source": "/api-auth/:path*",
      "destination": "https://county-inventory-system.onrender.com/api-auth/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://county-inventory-system.onrender.com/admin/:path*"
    },
    {
      "source": "/health",
      "destination": "https://county-inventory-system.onrender.com/health/"
    }
  ]
}