{
    "rewrites": [
    { "source": "/api/(.*)", "destination": "https://county-inventory-system.onrender.com/api/$1" },
    { "source": "/api-auth/(.*)", "destination": "https://county-inventory-system.onrender.com/api-auth/$1" },
    { "source": "/admin/(.*)", "destination": "https://county-inventory-system.onrender.com/admin/$1" },
    { "source": "/health", "destination": "https://county-inventory-system.onrender.com/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}